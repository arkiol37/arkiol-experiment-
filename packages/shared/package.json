{
  "name": "@arkiol/shared",
  "description": "ARKIOL v3 \u2014 Shared platform layer",
  "version": "25.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./src/*": {
      "types": "./src/*",
      "default": "./src/*"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "generate-types": "node scripts/generate-prisma-types.cjs",
    "db:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "db:seed": "tsx ../../apps/arkiol-core/prisma/seed.ts",
    "verify": "tsx scripts/verify-production.ts",
    "test": "jest --passWithNoTests --forceExit",
    "test:coverage": "jest --coverage --passWithNoTests --forceExit",
    "test:unit": "jest --testPathPattern=__tests__ --passWithNoTests --forceExit"
  },
  "dependencies": {
    "@prisma/client": "^5.16.1",
    "prisma": "^5.16.1",
    "stripe": "^15.7.0",
    "bullmq": "^5.8.1",
    "ioredis": "^5.4.1",
    "@upstash/redis": "^1.31.3",
    "@upstash/ratelimit": "^2.0.1",
    "zod": "^3.23.8",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.1",
    "nodemailer": "^6.9.14"
  },
  "devDependencies": {
    "typescript": "^5.5.3",
    "tsx": "^4.16.2",
    "@types/node": "^20.14.10",
    "@types/nodemailer": "^6.4.15",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "ts-jest": "^29.2.2"
  },
  "prisma": {
    "schema": "./prisma/schema.prisma"
  }
}
