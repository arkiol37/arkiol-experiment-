# ─────────────────────────────────────────────────────────────────────────────
# FOUNDER / OWNER ACCESS
# ─────────────────────────────────────────────────────────────────────────────
# Set this to the founder account email. On sign-in:
#   - Account is automatically promoted to SUPER_ADMIN
#   - Org is set to STUDIO plan with 999,999 credits
#   - All subscription, billing, and credit gates are bypassed
#   - No payment or bootstrap step required
# This is a server-only env var — never exposed to the client.
FOUNDER_EMAIL=



# ─────────────────────────────────────────────────────────────────────────────

# Required to use /api/admin/bootstrap — promotes your account to SUPER_ADMIN.
# Generate with: openssl rand -hex 32
# After bootstrapping, you can remove this or keep it for future use.

# Optional email-based bypass. Any requests from this email skip plan/credit
# gates even before you've run bootstrap. Useful for initial testing.
# Remove or leave blank in production after your account is promoted.

# ════════════════════════════════════════════════════════════════════════════
# ARKIOL PRODUCTION ENVIRONMENT VARIABLES
# Copy this file to .env.local for local development.
# NEVER commit .env.local or any file with real secret values.
# Set all variables in: Vercel Dashboard → Project → Settings → Env Vars
# ════════════════════════════════════════════════════════════════════════════

# ── AI ───────────────────────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
# Vercel: Mark as "Sensitive" — server-only, NEVER exposed to client bundles
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=org-...

# ── Database ─────────────────────────────────────────────────────────────────
# Recommended: Vercel Postgres, Neon, or Supabase
# Must include ?sslmode=require for production
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/arkiol?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/arkiol?sslmode=require
# Non-pooled URL for Prisma migrations (required for some providers)
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST:5432/arkiol?sslmode=require

# ── Redis ────────────────────────────────────────────────────────────────────
# BullMQ queue connection (use Redis Cloud, Railway Redis, or Upstash Redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# Upstash REST API for rate limiting (free tier available: upstash.com)
UPSTASH_REDIS_REST_URL=https://YOUR_ID.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN

# ── Authentication ────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_WITH_32_CHAR_RANDOM_STRING
NEXTAUTH_URL=https://app.arkiol.com

# Google OAuth (optional — get from console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AWS S3 ────────────────────────────────────────────────────────────────────
# Create an IAM user with S3 permissions: s3:PutObject, s3:GetObject, s3:DeleteObject, s3:HeadObject
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_BUCKET_NAME=arkiol-assets-prod

# CloudFront CDN (optional but recommended for asset delivery speed)
CLOUDFRONT_DOMAIN=https://cdn.arkiol.ai

# ── Application ────────────────────────────────────────────────────────────────
# Only NEXT_PUBLIC_ vars are safe to expose to the browser
NEXT_PUBLIC_APP_URL=https://app.arkiol.com

# Encryption key for webhook signing secrets (AES-256-GCM, 32 bytes)
# Generate with: openssl rand -hex 32
# REQUIRED — server will refuse to start if this is missing or malformed.
# Rotate by re-generating and re-creating all webhooks (existing ones become invalid).
WEBHOOK_SECRET_KEY=

# ── Monitoring ────────────────────────────────────────────────────────────────
# Get from: https://sentry.io (create a Next.js project)
SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ═══════════════════════════════════════════════════════════════════════════
# GITHUB SECRETS (add these to: GitHub Repo → Settings → Secrets → Actions)
# ═══════════════════════════════════════════════════════════════════════════
# VERCEL_TOKEN          = your Vercel access token (vercel.com/account/tokens)
# VERCEL_ORG_ID         = your Vercel team/org ID
# VERCEL_PROJECT_ID     = your Vercel project ID
# OPENAI_API_KEY_TEST   = separate OpenAI key for CI test runs (lower quota)
# UPSTASH_REDIS_REST_URL    = (same as above, needed in CI)
# UPSTASH_REDIS_REST_TOKEN  = (same as above, needed in CI)

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# For transactional emails (invites, password resets, job notifications)
# Options: SendGrid, Resend, AWS SES, Postmark, or any SMTP provider
# Leave blank to use console output in development
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=resend
SMTP_PASS=re_...
EMAIL_FROM="Arkiol <noreply@arkiol.ai>"

# ── Development seed (local only) ─────────────────────────────────────────────
# Used by: npm run db:seed
# NEVER set ALLOW_SEED=development in production — the seed script will refuse
# to run unless both NODE_ENV=development AND ALLOW_SEED=development are set.
# These passwords are for local development only and are never used in production.
ALLOW_SEED=development
SEED_ADMIN_PASSWORD=
SEED_DESIGNER_PASSWORD=

# Development email preview (Ethereal — no signup needed)
# Generate credentials: npx tsx -e "require('nodemailer').createTestAccount().then(a=>console.log(a))"
ETHEREAL_USER=
ETHEREAL_PASS=

# ── Stripe Billing ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── Monitoring ────────────────────────────────────────────────────────────────
MONITORING_SECRET=

# ── Worker ───────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=3

# ── Render backend (heavy generation service) ────────────────────────────────
# When BOTH variables are set, /api/generate forwards the heavy
# pipeline to the Render Node service instead of running it inline
# under Vercel's `waitUntil`. Required for the production split:
#
#   Vercel = UI + thin API + polling
#   Render = OpenAI + template composition + asset injection +
#            layout + rendering
#
# RENDER_BACKEND_URL — public URL of the Render service, no trailing slash.
# RENDER_GENERATION_KEY — shared secret; must match the same var on Render.
#
# If either is missing we fall back to the legacy inline path so
# preview deploys keep working.
RENDER_BACKEND_URL=
RENDER_GENERATION_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE SETUP (SUPABASE)
# ─────────────────────────────────────────────────────────────────────────────
# Option A — Single SQL file (recommended for fresh databases)
#   1. Open Supabase → SQL Editor
#   2. Paste contents of supabase-schema.sql (at repo root)
#   3. Click Run
#   This file is idempotent — safe to run multiple times.
#
# Option B — Prisma migrate deploy (for databases with existing migrations)
#   npm run db:deploy  (from apps/arkiol-core/)
#   This runs: prisma migrate deploy --schema=../../packages/shared/prisma/schema.prisma
#
# Both options produce an identical schema. Use Option A for new databases.
