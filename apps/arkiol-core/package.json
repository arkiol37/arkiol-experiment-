{
  "name": "@arkiol/core",
  "version": "25.0.0",
  "private": true,
  "description": "ARKIOL v3 \u2014 Core Design Platform",
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/vercel-prisma-generate.cjs && next build",
    "start": "next start",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit",
    "db:push": "npx prisma db push --schema=../../packages/shared/prisma/schema.prisma",
    "db:migrate": "npx prisma migrate dev --schema=../../packages/shared/prisma/schema.prisma",
    "db:deploy": "npx prisma migrate deploy --schema=../../packages/shared/prisma/schema.prisma",
    "db:studio": "npx prisma studio --schema=../../packages/shared/prisma/schema.prisma",
    "db:seed": "NODE_ENV=development ALLOW_SEED=development tsx prisma/seed.ts",
    "worker": "tsx --watch src/workers/index.ts",
    "worker:prod": "tsx src/workers/index.ts",
    "worker:gen": "tsx src/workers/generation.worker.ts",
    "worker:export": "tsx src/workers/export.worker.ts",
    "worker:webhook": "tsx src/workers/webhook.worker.ts",
    "verify:fonts": "tsx scripts/verify-fonts.ts",
    "test:e2e": "jest --testPathPattern=e2e-pipeline --forceExit",
    "test:integration": "jest --testPathPattern=(api-generate|api-export) --forceExit",
    "vercel-build": "node scripts/vercel-prisma-generate.cjs && next build",
    "test:unit": "jest --testPathPattern=__tests__ --passWithNoTests --forceExit"
  },
  "prisma": {
    "schema": "../../packages/shared/prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@arkiol/shared": "file:../../packages/shared",
    "@aws-sdk/client-s3": "^3.614.0",
    "@aws-sdk/s3-request-presigner": "^3.614.0",
    "@prisma/adapter-pg": "^5.16.1",
    "@prisma/client": "^5.16.1",
    "@sentry/nextjs": "^8.17.0",
    "@upstash/ratelimit": "^2.0.1",
    "@upstash/redis": "^1.31.3",
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.8.1",
    "html2canvas": "^1.4.1",
    "ioredis": "^5.4.1",
    "jose": "^5.3.0",
    "next": "14.2.5",
    "next-auth": "^4.24.7",
    "nodemailer": "^7.0.10",
    "openai": "^4.52.7",
    "pg": "^8.12.0",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.1",
    "prisma": "^5.16.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.3",
    "server-only": "^0.0.1",
    "sharp": "^0.33.4",
    "stripe": "^15.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/archiver": "^6.0.2",
    "@types/nodemailer": "^6.4.15",
    "typescript": "^5.5.3",
    "tsx": "^4.16.2",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "ts-jest": "^29.2.2",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.16.1",
    "eslint-config-next": "14.2.5",
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "optionalDependencies": {
    "canvas": "^2.11.2",
    "gif-encoder-2": "^1.0.4"
  }
}
