# ─── Server ────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5173

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/animation_studio
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# ─── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TLS=false
# REDIS_PASSWORD=yourredispassword

# ─── JWT (generate with: openssl rand -base64 64) ─────────────
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── Google OAuth (optional) ───────────────────────────────────
# GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ─── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PRO_MONTHLY=price_xxxxx
# STRIPE_PRICE_PRO_YEARLY=price_xxxxx
# STRIPE_PRICE_SCALE_MONTHLY=price_xxxxx
# STRIPE_PRICE_SCALE_YEARLY=price_xxxxx
# STRIPE_CREDIT_PACK_25=price_xxxxx
# STRIPE_CREDIT_PACK_100=price_xxxxx
# STRIPE_CREDIT_PACK_500=price_xxxxx

# ─── AWS S3 ────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_ASSETS=animation-studio-assets-dev
S3_BUCKET_RENDERS=animation-studio-renders-dev
CDN_URL=https://your-cloudfront-distribution.cloudfront.net

# ─── AI Video Providers (at least one required for renders) ────
# RUNWAY_API_KEY=key_xxxxxxxxxx
# RUNWAY_API_URL=https://api.runwayml.com/v1
# PIKA_API_KEY=your_pika_key
# PIKA_API_URL=https://api.pika.art/v1
# SORA_API_KEY=sk-proj-xxxxxxxx
# SORA_API_URL=https://api.openai.com/v1

# ─── ElevenLabs TTS (optional — for voiceover generation) ─────
# ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_API_URL=https://api.elevenlabs.io/v1

# ─── SendGrid (optional — for email notifications) ─────────────
# SENDGRID_API_KEY=SG.xxxxxx
EMAIL_FROM=noreply@animation-studio.ai

# ─── Encryption (generate with: openssl rand -hex 32) ─────────
# Must be exactly 64 hex chars (32 bytes)
ENCRYPTION_KEY=

# ─── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RENDER_RATE_LIMIT_MAX=10
RENDER_CONCURRENCY=3

# ─── Timeouts ──────────────────────────────────────────────────
FFMPEG_TIMEOUT_MS=600000
SCENE_POLL_TIMEOUT_MS=300000
SCENE_POLL_INTERVAL_MS=5000

# ─── Monitoring (optional) ─────────────────────────────────────
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
LOG_LEVEL=info

# ─── Feature flags ─────────────────────────────────────────────
FEATURE_4K_EXPORT=true
FEATURE_API_ACCESS=false
