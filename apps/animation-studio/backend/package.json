{
  "name": "@arkiol/animation-studio-backend",
  "version": "25.0.0",
  "description": "ARKIOL v3 — Animation Studio (rendering backend)",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:check": "tsc --noEmit",
    "start": "node dist/index.js",
    "worker": "tsx src/workers/renderWorker.ts",
    "worker:prod": "node dist/workers/renderWorker.js",
    "migrate": "knex --knexfile knexfile.ts migrate:latest",
    "migrate:rollback": "knex --knexfile knexfile.ts migrate:rollback",
    "migrate:status": "knex --knexfile knexfile.ts migrate:status",
    "migrate:make": "knex --knexfile knexfile.ts migrate:make",
    "seed": "knex --knexfile knexfile.ts seed:run",
    "test": "jest --config jest.config.ts --forceExit",
    "test:unit": "jest --config jest.config.ts tests/unit --forceExit",
    "test:integration": "jest --config jest.config.ts tests/integration --forceExit",
    "test:e2e": "jest --config jest.config.ts tests/e2e --runInBand --forceExit",
    "test:coverage": "jest --config jest.config.ts --coverage --forceExit",
    "test:watch": "jest --config jest.config.ts --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "health": "curl -sf http://localhost:4000/api/health | jq .",
    "test:smoke": "jest --config jest.config.ts tests/smoke --forceExit",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.540.0",
    "@aws-sdk/s3-presigned-post": "^3.540.0",
    "@aws-sdk/s3-request-presigner": "^3.540.0",
    "@bull-board/api": "^5.17.0",
    "@bull-board/express": "^5.17.0",
    "@sendgrid/mail": "^8.1.3",
    "@sentry/node": "^8.0.0",
    "argon2": "^0.31.2",
    "bull": "^4.12.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "google-auth-library": "^9.10.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.5",
    "sharp": "^0.33.3",
    "stripe": "^15.8.0",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "zod": "^3.23.6",
    "@arkiol/shared": "file:../../../packages/shared",
    "@prisma/client": "^5.16.1"
  },
  "devDependencies": {
    "@types/bull": "^4.10.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.5",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "ts-jest": "^29.1.4",
    "tsx": "^4.10.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
