# ARKIOL Render backend (generation service) — env template.
#
# Copy to .env for local dev; on Render, populate the service env
# vars in the dashboard or via render.yaml.

# ── HTTP ──────────────────────────────────────────────────────
# Port the Express server binds to. Render sets PORT automatically.
PORT=4100

# Comma-separated list of origins allowed to call this service.
# For production, set this to your Vercel deployment(s), e.g.
# https://app.arkiol.com,https://arkiol.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# Shared secret the Vercel frontend must send in the
# X-Arkiol-Render-Key header on /generate calls. Generate with
#   openssl rand -hex 32
# and set the SAME value as RENDER_GENERATION_KEY on Vercel.
RENDER_GENERATION_KEY=change-me-to-a-long-random-string

# ── Database (shared with Vercel frontend) ────────────────────
# Must point at the SAME Postgres as the Vercel deploy — jobs
# are created there and the backend reads/updates the same row.
DATABASE_URL=postgresql://user:pass@host:5432/arkiol

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── S3 / storage (optional; SVG data URLs fall back when absent) ─
S3_REGION=us-east-1
S3_BUCKET=arkiol-assets
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ── Runtime behaviour ────────────────────────────────────────
# NODE_ENV switches pino to JSON logs + turns on helmet hardening.
NODE_ENV=production

# Optional: set ARKIOL_SAFE_MODE=1 to shrink candidate fan-out
# when running on a small Render instance.
# ARKIOL_SAFE_MODE=1
