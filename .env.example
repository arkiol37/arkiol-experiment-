# ════════════════════════════════════════════════════════════════════════════
# ARKIOL — Root Environment Variables
# ════════════════════════════════════════════════════════════════════════════
# Copy to .env.local for local development. Never commit real secrets.
#
# For arkiol-core (Next.js): see apps/arkiol-core/.env.example
# For animation-studio backend: see apps/animation-studio/backend/.env.example
#   (or set in your hosting provider's environment)
#
# This monorepo is NOT a single-command deploy:
#   - apps/arkiol-core → deploy to Vercel (Next.js, UI + thin API only)
#   - apps/render-backend → deploy to Render.com (heavy generation
#     pipeline — see apps/render-backend/README.md and render.yaml)
#   - apps/animation-studio/backend → deploy to Railway / Fly.io / Docker
#     (requires persistent process for Bull queues + Redis)
#   - packages/shared → built locally, consumed by both apps
#
# Required infrastructure:
#   - PostgreSQL (Supabase / Neon / Vercel Postgres)
#   - Redis (Upstash / Railway Redis)
#   - S3-compatible storage (AWS S3 / Cloudflare R2)
#   - Stripe account (billing)
# ════════════════════════════════════════════════════════════════════════════

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/arkiol?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/arkiol?sslmode=require
REDIS_URL=redis://localhost:6379

# ── Render backend (heavy generation service) ──────────────────────
# When set, apps/arkiol-core/src/app/api/generate/route.ts forwards
# the heavy pipeline to the Render service instead of running it
# inline. Both variables must be set to enable the split — if either
# is missing we fall back to the legacy inline path.
RENDER_GENERATION_URL=https://arkiol-render-backend.onrender.com
RENDER_GENERATION_KEY=change-me-to-a-long-random-string
